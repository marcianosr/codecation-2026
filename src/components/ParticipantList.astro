---
import type { Participant } from '../data/participants';

interface Props {
  participants: Participant[];
}

const { participants } = Astro.props;

const SORT_OPTIONS = [
  { key: 'humor',   label: 'Droogste humor',    dir: 'desc' },
  { key: 'bugs',    label: 'Bugs gesquashed',    dir: 'desc' },
  { key: 'koffie',  label: 'Koffie p/dag',       dir: 'desc' },
  { key: 'lgtm',    label: 'Strengste reviewer', dir: 'asc'  },
  { key: 'commits', label: 'Vroegste commits',   dir: 'desc' },
] as const;
---

<div class="sort-bar" role="group" aria-label="Sorteer op">
  <span class="sort-label">Sorteer op</span>
  {SORT_OPTIONS.map((opt) => (
    <button class="sort-btn" data-sort-key={opt.key} data-sort-dir={opt.dir}>
      {opt.label}
    </button>
  ))}
</div>

<ul class="participant-list" id="participant-list">
  {participants.map((p) => (
    <li
      class="card-wrap"
      data-humor={p.stats.humor}
      data-bugs={p.stats.bugs}
      data-koffie={p.stats.koffie}
      data-lgtm={p.stats.lgtm}
      data-commits={p.stats.commits}
    >
      <div class="card">
        <div class="card-inner">

          <div class="card-front">
            <div class="photo-wrap">
              <img src={p.photo} alt={p.name} width="56" height="56" loading="lazy" />
            </div>
            <div class="front-info">
              <span class="name">{p.name}</span>
              <span class="hint">Tik voor stats</span>
            </div>
          </div>

          <div class="card-back">
            <span class="back-name">{p.name}</span>
            <p class="back-bio">{p.bio}</p>
            <dl class="stats">
              <div class="stat">
                <dt>Droogste humor</dt>
                <dd>{p.stats.humor}/100</dd>
              </div>
              <div class="stat">
                <dt>Bugs gesquashed</dt>
                <dd>{p.stats.bugs}</dd>
              </div>
              <div class="stat">
                <dt>Koffie p/dag</dt>
                <dd>{p.stats.koffie}</dd>
              </div>
              <div class="stat">
                <dt>LGTM ratio</dt>
                <dd>{p.stats.lgtm}%</dd>
              </div>
              <div class="stat">
                <dt>Commits &lt;09:00</dt>
                <dd>{p.stats.commits}</dd>
              </div>
            </dl>
          </div>

        </div>
      </div>
    </li>
  ))}
</ul>

<script>
  const list = document.getElementById('participant-list')!;

  // Flip
  list.addEventListener('click', (e) => {
    const card = (e.target as Element).closest('.card');
    if (!card) return;
    card.querySelector('.card-inner')?.classList.toggle('is-flipped');
  });

  // Sort
  document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.sortKey!;
      const dir = btn.dataset.sortDir as 'asc' | 'desc';

      document.querySelectorAll('.sort-btn').forEach((b) => b.classList.remove('sort-btn--active'));
      btn.classList.add('sort-btn--active');

      const items = Array.from(list.querySelectorAll<HTMLElement>('.card-wrap'));
      items.sort((a, b) => {
        const va = parseFloat(a.dataset[key] ?? '0');
        const vb = parseFloat(b.dataset[key] ?? '0');
        return dir === 'desc' ? vb - va : va - vb;
      });

      items.forEach((item) => list.appendChild(item));
    });
  });
</script>

<style>
  .sort-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .sort-label {
    font-size: 0.75rem;
    color: var(--muted);
    margin-right: 0.25rem;
  }

  .sort-btn {
    font-size: 0.75rem;
    padding: 0.3rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: none;
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .sort-btn:hover {
    color: var(--text);
    border-color: #9ca3af;
  }

  .sort-btn--active {
    background: var(--text);
    color: #fff;
    border-color: var(--text);
  }

  .participant-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Flip card ── */

  .card-wrap {
    perspective: 800px;
  }

  .card {
    cursor: pointer;
    height: 100px;
    position: relative;
  }

  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-inner.is-flipped {
    transform: rotateY(180deg);
  }

  .card-front,
  .card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.875rem 1rem;
    background: var(--bg);
  }

  /* Front */

  .card-front {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .photo-wrap {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: #f3f4f6;
  }

  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .front-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .name {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .hint {
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* Back */

  .card-back {
    transform: rotateY(180deg);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    height: auto;
    min-height: 100%;
  }

  .card-wrap:has(.is-flipped) .card {
    height: auto;
    min-height: 100px;
  }

  .back-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--muted);
  }

  .back-bio {
    font-size: 0.75rem;
    color: var(--muted);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.25rem;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem 1rem;
  }

  .stat {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.75rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.2rem;
  }

  .stat:nth-child(5) {
    grid-column: 1 / -1;
  }

  .stat dt {
    color: var(--muted);
  }

  .stat dd {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
</style>
