---
import type { Participant } from '../data/participants';

interface Props {
  participants: Participant[];
}

const { participants } = Astro.props;

const SORT_OPTIONS = [
  { key: 'humor',   label: 'Droogste humor',    dir: 'desc' },
  { key: 'bugs',    label: 'Bugs gesquashed',    dir: 'desc' },
  { key: 'koffie',  label: 'Koffie p/dag',       dir: 'desc' },
  { key: 'lgtm',    label: 'Strengste reviewer', dir: 'asc'  },
  { key: 'commits', label: 'Vroegste commits',   dir: 'desc' },
] as const;
---

<div class="sort-bar" role="group" aria-label="Sorteer op">
  <span class="sort-label">Sorteer op</span>
  {SORT_OPTIONS.map((opt) => (
    <button class="sort-btn" data-sort-key={opt.key} data-sort-dir={opt.dir}>
      {opt.label}
    </button>
  ))}
</div>

<ul class="participant-list" id="participant-list">
  {participants.map((p) => (
    <li
      class="participant"
      data-humor={p.stats.humor}
      data-bugs={p.stats.bugs}
      data-koffie={p.stats.koffie}
      data-lgtm={p.stats.lgtm}
      data-commits={p.stats.commits}
    >
      <button class="participant-toggle" aria-expanded="false">
        <div class="photo-wrap">
          <img src={p.photo} alt={p.name} width="56" height="56" loading="lazy" />
        </div>
        <div class="toggle-info">
          <span class="name">{p.name}</span>
          <span class="hint">Tik voor stats</span>
        </div>
        <span class="chevron" aria-hidden="true">›</span>
      </button>

      <div class="stats-panel">
        <div class="stats-inner">
        <p class="bio">{p.bio}</p>
        <dl class="stats">
          <div class="stat">
            <dt>Droogste humor</dt>
            <dd>{p.stats.humor}/100</dd>
          </div>
          <div class="stat">
            <dt>Bugs gesquashed</dt>
            <dd>{p.stats.bugs}</dd>
          </div>
          <div class="stat">
            <dt>Koffie p/dag</dt>
            <dd>{p.stats.koffie}</dd>
          </div>
          <div class="stat">
            <dt>LGTM ratio</dt>
            <dd>{p.stats.lgtm}%</dd>
          </div>
          <div class="stat">
            <dt>Commits &lt;09:00</dt>
            <dd>{p.stats.commits}</dd>
          </div>
        </dl>
        </div>
      </div>
    </li>
  ))}
</ul>

<script>
  const list = document.getElementById('participant-list')!;

  // Toggle stats panel
  list.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.participant-toggle');
    if (!btn) return;

    const participant = btn.closest('.participant')!;
    const isOpen = participant.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // Sort
  document.querySelectorAll<HTMLButtonElement>('.sort-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.sortKey!;
      const dir = btn.dataset.sortDir as 'asc' | 'desc';

      document.querySelectorAll('.sort-btn').forEach((b) => b.classList.remove('sort-btn--active'));
      btn.classList.add('sort-btn--active');

      const items = Array.from(list.querySelectorAll<HTMLElement>('.participant'));
      items.sort((a, b) => {
        const va = parseFloat(a.dataset[key] ?? '0');
        const vb = parseFloat(b.dataset[key] ?? '0');
        return dir === 'desc' ? vb - va : va - vb;
      });

      items.forEach((item) => list.appendChild(item));
    });
  });
</script>

<style>
  /* Sort bar */

  .sort-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .sort-label {
    font-size: 0.75rem;
    color: var(--muted);
    margin-right: 0.25rem;
  }

  .sort-btn {
    font-size: 0.75rem;
    padding: 0.3rem 0.625rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: none;
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .sort-btn:hover {
    color: var(--text);
    border-color: #9ca3af;
  }

  .sort-btn--active {
    background: var(--text);
    color: #fff;
    border-color: var(--text);
  }

  /* List */

  .participant-list {
    display: flex;
    flex-direction: column;
  }

  .participant {
    border-bottom: 1px solid var(--border);
  }

  .participant:last-child {
    border-bottom: none;
  }

  /* Toggle row */

  .participant-toggle {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    width: 100%;
    padding: 0.875rem 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }

  .photo-wrap {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: hidden;
    background: #f3f4f6;
  }

  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .toggle-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .name {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .hint {
    font-size: 0.75rem;
    color: var(--muted);
  }

  .chevron {
    font-size: 1.25rem;
    color: var(--muted);
    line-height: 1;
    transition: transform 0.25s;
    transform: rotate(90deg);
  }

  .participant.is-open .chevron {
    transform: rotate(270deg);
  }

  /* Stats panel — expand with grid trick */

  .stats-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .participant.is-open .stats-panel {
    grid-template-rows: 1fr;
  }

  .stats-inner {
    overflow: hidden;
    min-height: 0;
  }

  /* Content inside the panel */

  .bio {
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.5;
    padding-bottom: 0.75rem;
  }

  .stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1rem;
    padding-bottom: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .stat:last-child {
    grid-column: 1 / -1;
  }

  .stat dt {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
  }

  .stat dd {
    font-size: 0.9375rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
</style>
