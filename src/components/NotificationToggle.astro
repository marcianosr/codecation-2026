<div id="notif-wrap">
  <button id="notif-btn">🔔 Notificaties inschakelen</button>
  <p id="notif-msg"></p>
</div>

<script>
  const wrap = document.getElementById('notif-wrap')!;
  const btn = document.getElementById('notif-btn') as HTMLButtonElement;
  const msg = document.getElementById('notif-msg')!;

  const MINUTES_BEFORE = 15;

  if (!('Notification' in window)) {
    wrap.hidden = true;
  } else {
    init();
  }

  function scheduleNotifications(): number {
    const items = document.querySelectorAll<HTMLElement>('[data-start][data-date]');
    let count = 0;

    for (const item of items) {
      const { start, date, activity } = item.dataset;
      if (!start || !date || !activity) continue;

      const [h, m] = start.split(':').map(Number);
      const hh = String(h).padStart(2, '0');
      const mm = String(m).padStart(2, '0');
      const activityTime = new Date(`${date}T${hh}:${mm}:00+02:00`);
      const delay = activityTime.getTime() - MINUTES_BEFORE * 60_000 - Date.now();

      if (delay <= 0) continue;

      setTimeout(() => {
        new Notification(activity, { body: `Begint over ${MINUTES_BEFORE} minuten` });
      }, delay);

      count++;
    }

    return count;
  }

  function setActive(): void {
    btn.textContent = '✓ Notificaties aan';
    btn.disabled = true;
    msg.textContent = `Je krijgt een melding ${MINUTES_BEFORE} min voor elk onderdeel. Laat deze pagina open.`;
  }

  function setDenied(): void {
    btn.hidden = true;
    msg.textContent = 'Sta notificaties toe via je browserinstellingen.';
  }

  function init(): void {
    if (Notification.permission === 'granted') {
      scheduleNotifications();
      setActive();
      return;
    }

    if (Notification.permission === 'denied') {
      setDenied();
      return;
    }

    btn.addEventListener('click', async () => {
      const permission = await Notification.requestPermission();
      if (permission === 'granted') {
        scheduleNotifications();
        setActive();
      } else {
        setDenied();
      }
    });
  }
</script>

<style>
  #notif-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  #notif-wrap[hidden] {
    display: none;
  }

  #notif-btn {
    font-size: 0.8125rem;
    padding: 0.375rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: none;
    cursor: pointer;
    white-space: nowrap;
    transition: border-color 0.15s, background 0.15s;
  }

  #notif-btn:hover:not(:disabled) {
    border-color: #9ca3af;
    background: #f9fafb;
  }

  #notif-btn:disabled {
    cursor: default;
    color: #16a34a;
    border-color: #bbf7d0;
    background: #f0fdf4;
  }

  #notif-msg {
    font-size: 0.75rem;
    color: var(--muted);
  }
</style>
