---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'CodeCation 2026' } = Astro.props;
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const isSchedule = currentPath === base || currentPath === `${base}/`;
const isDeelnemers = currentPath.includes('deelnemers');
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="CodeCation 2026 — programma en deelnemers" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <span class="wordmark">CodeCation <strong>2026</strong></span>
        <nav>
          <a href={base || '/'} class:list={['nav-link', { active: isSchedule }]}>Programma</a>
          <a href={`${base}/deelnemers`} class:list={['nav-link', { active: isDeelnemers }]}>Deelnemers</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  header {
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .wordmark {
    font-size: 1rem;
    white-space: nowrap;
  }

  nav {
    display: flex;
    gap: 0.25rem;
  }

  .nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: var(--text);
    background: #f3f4f6;
  }

  .nav-link.active {
    color: var(--text);
    font-weight: 500;
  }

  main {
    flex: 1;
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }
</style>
